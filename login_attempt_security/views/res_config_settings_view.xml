<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="res_config_settings_view_form_login_security" model="ir.ui.view">
        <field name="name">res.config.settings.form.login.security</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//block[@id='user_default_rights']" position="after">

                <block title="Login Security" id="login_security_block">

                    <setting>
                        <span>
                            Maximum login attempts:
                            <field name="login_max_attempts" class="oe_inline"/>
                        </span>
                    </setting>

                    <setting>
                        <span>
                            Block user for
                            <field name="login_block_minutes" class="oe_inline"/>
                            minutes after limit reached.
                        </span>
                    </setting>

                </block>

            </xpath>

        </field>
    </record>

</odoo>