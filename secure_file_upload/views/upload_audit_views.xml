<odoo>
    <record id="view_secure_upload_audit_tree" model="ir.ui.view">
        <field name="name">secure.upload.audit.tree</field>
        <field name="model">secure.upload.audit</field>
        <field name="arch" type="xml">
            <list>
                <field name="user_id"/>
                <field name="filename"/>
                <field name="file_size"/>
                <field name="mime_type"/>
                <field name="result"/>
                <field name="reason"/>
                <field name="timestamp"/>
            </list>
        </field>
    </record>

    <record id="action_upload_audit" model="ir.actions.act_window">
        <field name="name">Upload Audit Logs</field>
        <field name="res_model">secure.upload.audit</field>
        <field name="view_mode">list</field>
    </record>

    <menuitem id="menu_upload_audit"
              name="Upload Audits"
              parent="base.menu_administration"
              action="action_upload_audit"/>
</odoo>